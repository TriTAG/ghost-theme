{{!< default }}

<main class="site-main">

    {{! IONizeWR callout}}
    <section class="p-outer gh-canvas">
        <div class="p-inner gh-content">
            <h2>Let's IONize Waterloo Region!</h2>
            <p>
              TriTAG's latest campaign, <strong>IONize Waterloo Region</strong>, envisions a
              complete, reliable rapid transit network that connects Cambridge, Kitchener, and
              Waterloo – guiding growth, improving access, and strengthening our region. It’s
              time to build ION Stage 2, the full LRT
              extension to Cambridge, and then to keep building.
            </p>

            <form>
              <button class="button" formaction="/ionizewr/">Read more about IONizeWR!</button>
            </form>
            <p></p>
        </div>
    </section>

    <header class="feed-header gh-canvas">
        {{#if @custom.feed_title}}
            <div class="feed-header-wrapper">
                <h2 class="feed-header-title" style="font-size: 2.8rem; text-transform: none">{{@custom.feed_title}}</h2>
            </div>
        {{/if}}
    </header>

    <div class="post-feed{{#match @custom.feed_layout "!=" "Minimal"}} expanded{{/match}}{{#match @custom.feed_layout "Right thumbnail"}} right-thumbnail{{/match}}{{#match @custom.feed_layout "Text-only"}} text-only{{/match}} gh-feed gh-canvas">
        {{#foreach posts}}
            {{> "loop"}}
        {{/foreach}}
    </div>

    {{pagination}}

</main>

{{#contentFor "body_class"}}{{#if @site.cover_image}} with-full-cover is-head-transparent{{/if}}{{#if @member}} logged-in{{/if}}{{/contentFor}}
